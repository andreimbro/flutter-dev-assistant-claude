  "description": "Enterprise-grade AI development companion for Flutter with intelligent code analysis, widget optimization, state management guidance, security auditing, comprehensive verification, and multi-agent orchestration",
  "author": {
    "name": "andreimbro",
    "url": "https://github.com/andreimbro"
  },
  "homepage": "https://github.com/andreimbro/flutter-dev-assistant-claude",
